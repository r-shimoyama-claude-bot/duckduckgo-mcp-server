# DuckDuckGo MCP Server configuration
# Copy this file to .env and fill in your values.

# --- Search settings ---
# SafeSearch: STRICT | MODERATE (default) | OFF
# DDG_SAFE_SEARCH=MODERATE

# Default region: us-en, jp-ja, uk-en, de-de, fr-fr, wt-wt, etc.
# DDG_REGION=

# Min seconds between requests (default: 2.0)
# DDG_THROTTLE=2.0

# Throttle jitter fraction (default: 0.3 = +-30%)
# DDG_THROTTLE_JITTER=0.3

# Rotate HTTP session every N requests (default: 10)
# DDG_SESSION_ROTATION_INTERVAL=10

# Retry base delay on 202/429 (default: 3.0)
# DDG_RETRY_DELAY=3.0

# Max retries on CAPTCHA/rate-limit (default: 3)
# DDG_MAX_RETRIES=3

# --- Proxy (single) ---
# SOCKS5 proxy for Tor, e.g. socks5h://127.0.0.1:9050
# DDG_PROXY=

# Override DDG Lite endpoint (e.g. Tor Onion address)
# DDG_BASE_URL=https://duckduckgogg42xjoc72x3sjasowoarfbgcmvfimaftt6twagswzczad.onion/lite/

# --- Proxy pool (residential, recommended) ---
# Comma-separated list: ip:port:user:pass
# DDG_PROXIES=1.2.3.4:8080:user:pass,5.6.7.8:9090:user2:pass2

# Target seconds between searches across all proxies (default: 5.0)
# Throttle per proxy = target / active_count (e.g. 3.0/10 = 0.3s)
# DDG_PROXIES_TARGET_INTERVAL=3.0

# Seconds to block a proxy after CAPTCHA/403 (default: 300.0)
# DDG_PROXIES_COOLDOWN=300.0

# --- Fetch content ---
# Per-domain throttle for fetch_content in seconds (default: 1.0)
# DDG_FETCH_THROTTLE=1.0
